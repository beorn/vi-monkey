{
  "name": "vimonkey",
  "version": "0.2.0",
  "description": "Fuzz testing with auto-shrinking and composable chaos stream transformers for Vitest",
  "keywords": [
    "async-generator",
    "auto-shrink",
    "chaos",
    "chaos-engineering",
    "delta-debugging",
    "fuzz",
    "fuzzing",
    "property-based-testing",
    "seeded-random",
    "shrinking",
    "stream-transformer",
    "testing",
    "vitest",
    "vitest-plugin"
  ],
  "homepage": "https://github.com/beorn/vimonkey",
  "bugs": {
    "url": "https://github.com/beorn/vimonkey/issues"
  },
  "license": "MIT",
  "author": "Beorn",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/vimonkey.git"
  },
  "files": [
    "src",
    "dist"
  ],
  "type": "module",
  "module": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./plugin": "./src/plugin.ts",
    "./fuzz": "./src/fuzz/index.ts",
    "./chaos": "./src/chaos/index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "debug": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  },
  "peerDependencies": {
    "vitest": ">=4.0.0"
  }
}
